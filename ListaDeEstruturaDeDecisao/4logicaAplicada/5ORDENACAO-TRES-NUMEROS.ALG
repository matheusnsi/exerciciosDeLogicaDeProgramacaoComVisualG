Algoritmo "Ordenacao-tres-numeros"
// Disciplina   : Lógica de Programaçăo com VisualG
// Professor   : Jailson
// Descriçăo   : Lę tręs números e os exibe em ordem crescente.
// Autor(a)    : Matheus Nascimento Silveira
// Data atual  : 19/04/2026
Var
A: real
B: real
C: real

Inicio
Escreval("Ordenaçăo de Tręs Números")
Escreva("Digite o primeiro número (A): ")
Leia(A)
Escreva("Digite o segundo número (B): ")
Leia(B)
Escreva("Digite o terceiro número (C): ")
Leia(C)
Escreval("Números em ordem crescente:")
Se (A < B) E (A < C) entao
   Se (B < C) entao
      Escreval(A, " ", B, " ", C)
   Senao
      Escreval(A, " ", C, " ", B)
   Fimse
Senao
   Se (B < A) E (B < C) entao
      Se (A < C) entao
         Escreval(B, " ", A, " ", C)
      Senao
         Escreval(B, " ", C, " ", A)
      Fimse
   Senao
      Se (C < A) E (C < B) entao
         Se (A < B) entao
            Escreval(C, " ", A, " ", B)
         Senao
            Escreval(C, " ", B, " ", A)
         Fimse
      Fimse
   Fimse
Fimse
Fimalgoritmo