Algoritmo "Idade-Em-Dias"
// Disciplina  : Lógica de Programaçăo com visualG
// Professor   : Jailson
// Descriçăo   : Converte idade (anos, meses, dias) para o total em dias.
// Autor(a)    : Matheus Nascimento Silveira
// Data atual  : 22/04/2026
Var
anos, meses, dias, total_dias: inteiro

Inicio
Escreval("Digite sua idade em anos, meses e dias:")
Escreva("Anos: ")
Leia(anos)
Escreva("Meses: ")
Leia(meses)
Escreva("Dias: ")
Leia(dias)

total_dias <- (anos * 365) + (meses * 30) + dias

Escreval("Vocę viveu aproximadamente ", total_dias, " dias.")
Fimalgoritmo